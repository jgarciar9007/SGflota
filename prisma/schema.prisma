// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id        String   @id @default(uuid())
  name      String
  type      String
  range     String
  price     Int
  image     String
  images    String[] @default([])
  status    String   // "Disponible" | "Rentado" | "Mantenimiento"
  plate     String
  year      Int
  ownership String   // "Propia" | "Tercero"
  seats     Int      @default(5)
  ownerName String?
  ownerDni  String?

  rentals           Rental[]
  maintenances      Maintenance[]
  vehicleDocuments  VehicleDocument[]
  vehicleInsurances VehicleInsurance[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookingRequests BookingRequest[]
}

model Client {
  id      String   @id @default(uuid())
  name    String
  email   String   @unique
  phone   String
  address String
  dni     String   @unique

  rentals  Rental[]
  invoices Invoice[]
  payments Payment[]
  refunds  Refund[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rental {
  id              String   @id @default(uuid())
  vehicleId       String
  clientId        String
  startDate       DateTime
  endDate         DateTime
  originalEndDate DateTime?
  dailyRate       Int
  status          String   // "Activo" | "Finalizado"
  totalAmount     Int?
  commercialAgent String?
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice?
  accountsPayable AccountPayable[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  rentalId      String?  @unique
  clientId      String
  amount        Int
  paidAmount    Int      @default(0)
  date          DateTime
  status        String   // "Pagado" | "Pendiente" | "Parcial"
  rentalDetails String?  // JSON string for snapshot

  rental   Rental? @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  client   Client  @relation(fields: [clientId], references: [id])
  payments   Payment[]
  refunds    Refund[]
  expenses   Expense[]
  ivaRecords IvaRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id        String   @id @default(uuid())
  receiptId String
  clientId  String
  invoiceId String
  amount    Int
  paymentNumber String? @unique // Custom numbering P-XXX/YY
  date      DateTime
  method    String

  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  invoiceId String
  clientId  String
  amount    Int
  refundNumber String? @unique // Custom numbering R-XXX/YY
  date      DateTime
  reason    String
  status    String   @default("Pendiente") // Pendiente, Reembolsado

  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())
}

model Maintenance {
  id          String   @id @default(uuid())
  vehicleId   String
  description String
  date        DateTime
  cost        Int
  status      String   // "Programado" | "En Proceso" | "Completado"
  type        String?
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanySettings {
  id      Int    @id @default(1)
  name    String
  logo    String
  address String
  phone   String
  email   String
  taxId   String
  website String
}

model User {
  id     String @id @default(uuid())
  name   String
  email  String @unique
  role   String // "Admin" | "User" | "Registrar"
  status String // "Active" | "Inactive"
  password String @default("123456")
  avatar String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseCategory {
  id          String @id @default(uuid())
  name        String
  description String?
  type        String   @default("Gasto") // "Gasto" | "Ingreso"
  expenses          Expense[]
  vehicleDocuments  VehicleDocument[]
  vehicleInsurances VehicleInsurance[]
}

model Expense {
  id          String   @id @default(uuid())
  date        DateTime
  amount      Int
  expenseNumber String? @unique // Custom numbering G-XXX/YY
  description String
  categoryId  String
  invoiceId   String?
  status      String   // "Pagado" | "Pendiente"

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  invoice  Invoice?        @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Owner {
  id     String @id @default(uuid())
  name   String
  dni    String @unique
  phone  String
  email  String @unique
  status String // "Activo" | "Inactivo"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommercialAgent {
  id     String @id @default(uuid())
  name   String
  dni    String @unique
  phone  String
  email  String @unique
  status String // "Activo" | "Inactivo"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountPayable {
  id              String   @id @default(uuid())
  rentalId        String
  type            String   // "Propietario" | "Comercial"
  beneficiaryName String
  beneficiaryDni  String?
  amount          Int
  date            DateTime
  status          String   // "Pendiente" | "Pagado"

  rental Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Personnel {
  id            String   @id @default(uuid())
  name          String
  dni           String   @unique
  phone         String
  email         String?
  role          String   // "Conductor" | "Administrativo" | "Mecánico" | "Otro"
  licenseNumber String?  // Only for Drivers
  salary        Int?     // Only for Staff (FCFA)
  status        String   // "Activo" | "Inactivo"
  
  driverPayments DriverPayment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DriverPayment {
  id          String    @id @default(uuid())
  personnelId String
  amount      Int
  date        DateTime
  concept     String
  notes       String?

  personnel   Personnel @relation(fields: [personnelId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payroll {
  id          String   @id @default(uuid())
  month       Int
  year        Int
  totalAmount Int
  status      String   // "Borrador" | "Pagado"
  details     String   // JSON: [{ personnelId, name, salary, bonus, deduction, total }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingRequest {
  id              String   @id @default(uuid())
  vehicleId       String?
  vehicleName     String?  // In case selected vehicle is deleted
  clientName      String
  clientEmail     String
  clientPhone     String
  clientAddress   String?
  startDate       DateTime
  endDate         DateTime?
  services        String?  // JSON input: { withDriver: boolean, fuel: boolean, tolls: boolean }
  status          String   @default("Pendiente") // "Pendiente" | "Aceptado" | "Rechazado"
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  message   String
  status    String   @default("Pendiente") // "Pendiente" | "Atendido"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IvaRecord {
  id          String   @id @default(uuid())
  invoiceId   String
  amount      Int      // IVA amount = paidAmount * 15/115
  baseAmount  Int      // The paid amount that generated this IVA
  paymentDate DateTime
  period      String   // "YYYY-MM"
  status      String   @default("Pendiente") // "Pendiente" | "Pagado"
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VehicleDocument {
  id            String   @id @default(uuid())
  vehicleId     String
  categoryId    String?
  documentType  String   // "Permiso de Circulación" | "Revisión Técnica" | "SOAT" | "Seguro CIMA" | "Otro"
  description   String
  amount        Int
  issueDate     DateTime
  expiryDate    DateTime
  status        String   // "Vigente" | "Próximo a Vencer" | "Vencido"
  paymentStatus String   @default("Pagado") // "Pagado" | "Pendiente"
  notes         String?
  vehicle       Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VehicleInsurance {
  id            String   @id @default(uuid())
  vehicleId     String
  categoryId    String?
  insurer       String
  policyNumber  String
  coverageType  String
  amount        Int
  startDate     DateTime
  expiryDate    DateTime
  status        String   // "Vigente" | "Próximo a Vencer" | "Vencido"
  paymentStatus String   @default("Pagado") // "Pagado" | "Pendiente"
  notes         String?
  vehicle       Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// BANCO Y EFECTIVO
// ============================================================

model Bank {
  id        String        @id @default(uuid())
  name      String
  code      String?
  active    Boolean       @default(true)
  accounts  BankAccount[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model BankAccount {
  id             String            @id @default(uuid())
  bankId         String
  name           String
  accountNumber  String?
  type           String            @default("Corriente") // "Corriente" | "Ahorros"
  openingBalance Int               @default(0)
  currentBalance Int               @default(0)
  active         Boolean           @default(true)
  bank           Bank              @relation(fields: [bankId], references: [id], onDelete: Restrict)
  transactions   BankTransaction[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model PettyCash {
  id             String            @id @default(uuid())
  name           String
  openingBalance Int               @default(0)
  currentBalance Int               @default(0)
  active         Boolean           @default(true)
  transactions   CashTransaction[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model BankTransaction {
  id            String      @id @default(uuid())
  bankAccountId String
  type          String      // "Deposito" | "Retiro" | "Transferencia"
  amount        Int
  date          DateTime
  description   String
  reference     String?
  paymentId     String?
  expenseId     String?
  transferId    String?
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())
}

model CashTransaction {
  id          String    @id @default(uuid())
  pettyCashId String
  type        String    // "Ingreso" | "Egreso"
  category    String    // "Pago de Renta" | "Gasto Operativo" | "Depósito a Banco" | "Otro"
  amount      Int
  date        DateTime
  description String
  reference   String?
  paymentId   String?
  expenseId   String?
  transferId  String?
  pettyCash   PettyCash @relation(fields: [pettyCashId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
}

model Transfer {
  id                  String   @id @default(uuid())
  type                String   // "BancoABanco" | "CajaABanco"
  amount              Int
  date                DateTime
  description         String
  sourceBankAccountId String?
  destBankAccountId   String?
  pettyCashId         String?
  createdAt           DateTime @default(now())
}